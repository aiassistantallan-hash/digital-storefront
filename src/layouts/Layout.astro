---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Fully Automated Digital Product Storefront" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <style is:global>
      :root { --accent: 79, 70, 229; }
      html { font-family: 'Inter', sans-serif; background: #0f172a; color: #f8fafc; }
      .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 16px; }
    </style>
  </head>
  <body><slot /></body>
</html>
